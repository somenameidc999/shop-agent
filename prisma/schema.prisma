// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id          String   @id @default(cuid())
  shop        String   @unique
  name        String
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model McpServerConfig {
  id           String   @id @default(cuid())
  shop         String
  serverType   String
  instanceName String   @default("default")
  enabled      Boolean  @default(false)
  configJson   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, serverType, instanceName])
}

model Goal {
  id                 String              @id @default(cuid())
  shop               String
  ruleKey            String
  title              String
  description        String
  category           String
  priority           String              @default("medium")
  requiredServers    String
  analysisPrompt     String
  actionPrompt       String
  enabled            Boolean             @default(true)
  cronIntervalMins   Int                 @default(240)
  outcomeMeasureDays Int                 @default(7)
  eventDriven        Boolean             @default(false)
  eventTriggers      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  executions         GoalExecution[]
  goalExecutionLinks GoalExecutionGoal[] @relation("GoalExecutionLinks")
  feedbacks          MerchantFeedback[]

  @@unique([shop, ruleKey])
}

model GoalExecution {
  id                     String              @id @default(cuid())
  shop                   String
  goalId                 String
  title                  String
  description            String
  category               String
  priority               String
  status                 String              @default("new")
  actionPrompt           String
  mcpServersUsed         String
  metadata               String?
  resultSummary          String?
  impactScore            Float?
  confidenceLevel        String?
  estimatedRevenue       String?
  estimatedConversionLift String?
  estimatedAovImpact     String?
  impactReasoning        String?
  actionSteps            String?
  outcomeStatus          String?
  outcomeData            String?
  outcomeMeasuredAt      DateTime?
  baselineData           String?
  dismissedAt            DateTime?
  dismissedBy            String?
  dryRunResult           String?
  customParameters       String?
  triggerSource          String?
  webhookEventType       String?
  escalatedAt            DateTime?
  feedbackRating         Int?
  feedbackNote           String?
  compositeScore         Float?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  expiresAt              DateTime?
  executedAt             DateTime?
  goal                   Goal                @relation(fields: [goalId], references: [id])
  goalExecutionLinks     GoalExecutionGoal[]
  feedbacks              MerchantFeedback[]

  @@index([shop, status])
  @@index([shop, goalId])
}

model GoalExecutionGoal {
  id              String        @id @default(cuid())
  goalExecutionId String
  goalId          String
  goalExecution   GoalExecution @relation(fields: [goalExecutionId], references: [id], onDelete: Cascade)
  goal            Goal          @relation("GoalExecutionLinks", fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalExecutionId, goalId])
  @@index([goalId])
}

model BackgroundJob {
  id          String    @id @default(cuid())
  shop        String
  jobType     String
  status      String    @default("pending")
  payload     String
  result      String?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([shop, jobType])
}

model MerchantFeedback {
  id            String        @id @default(cuid())
  shop          String
  goalId        String
  executionId   String?
  feedbackType  String
  rating        Int?
  note          String?
  createdAt     DateTime      @default(now())
  goal          Goal          @relation(fields: [goalId], references: [id])
  execution     GoalExecution? @relation(fields: [executionId], references: [id])

  @@index([shop, goalId])
  @@index([shop, feedbackType])
}
